#!/usr/bin/env bash
#
# dot
#
# `dot` handles installation, updates, things like that. Run it periodically
# to make sure you're on the latest and greatest.

cd "$(dirname "$0")/.."
DOTFILES_ROOT=$(pwd)

IS_MAC_OS=""
if [[ "$OSTYPE" == darwin* ]]; then
      IS_MAC_OS=true
fi

# Install homebrew packages
bash $DOTFILES_ROOT/homebrew/install.sh

# beautify vim ls terminal
bash $DOTFILES_ROOT/beautify/install.sh

# Set up oh-my-zsh
bash $DOTFILES_ROOT/zsh/install.sh

# Set OS X defaults
#bash $DOTFILES_ROOT/osx/set-defaults.sh

# Set up python env
bash $DOTFILES_ROOT/python/install.sh

# Set up ruby
#bash $DOTFILES_ROOT/ruby/install.sh

# Set up spf13-vim
bash $DOTFILES_ROOT/vim/install.sh

# Set up sdkman
bash $DOTFILES_ROOT/sdkman/install.sh

# Set up iterm2
bash $DOTFILES_ROOT/iterm2/install.sh

# Set up karabiner
bash $DOTFILES_ROOT/karabiner/install.sh

# Set up hammerspoon
bash $DOTFILES_ROOT/hammerspoon/install.sh

# Set up tmux
bash $DOTFILES_ROOT/tmux/install.sh

# Set jdk
bash $DOTFILES_ROOT/java/install.sh
